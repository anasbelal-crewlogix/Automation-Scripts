# Copy to ".env" in this folder (never commit .env).
# Slack: Your App → Incoming Webhooks → add one webhook per channel → copy each URL.

# --- Single channel ---
SLACK_WEBHOOK_URL=

# --- Multiple channels (pick ONE style) ---
#
# Style A — one variable, BOTH URLs on the SAME line, separated by commas (do NOT put the second URL on the next line):
# SLACK_WEBHOOK_URLS=https://hooks.slack.com/services/AAA/BBB/CCC,https://hooks.slack.com/services/XXX/YYY/ZZZ
#
# Style B — two variables (script merges both):
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/AAA/BBB/CCC
# SLACK_WEBHOOK_URLS=https://hooks.slack.com/services/XXX/YYY/ZZZ
#
# Wrong (only the last line wins in .env): two lines both saying SLACK_WEBHOOK_URLS=

# Optional: set to 0 to only post to Slack when the run fails
# SLACK_NOTIFY_ON_SUCCESS=1

# Optional: path to WDIO JSON reporter output (default: logs/wdio-last-result.json)
# SLACK_WDIO_JSON=

# --- Cosmedics provider (optional overrides; spec has defaults) ---
# COSMEDICS_PROVIDER_EMAIL=
# COSMEDICS_PROVIDER_PASSWORD=
# COSMEDICS_PROVIDER_CLINIC_NAME=   # substring of the clinic row to tap when picker appears
# COSMEDICS_PROVIDER_POST_LOGIN_PAUSE_MS=400   # ms after clinic sheet detected, before tapping selection (max 2000 in spec)
# COSMEDICS_PROVIDER_POST_CLINIC_LANDING_PAUSE_MS=800   # ms on dashboard after clinic Apply, before Profile (max 2000)
# COSMEDICS_PROVIDER_LEAVE_LOGIN_TIMEOUT_MS=60000   # max wait after provider Continue for clinic or leaving login
# COSMEDICS_CLINIC_SCREEN_MARKER=    # substring unique to clinic selection title if auto-detect misses
# COSMEDICS_PROVIDER_START_AT_PROFILE=1   # skip sign-in/clinic; only open Profile (npm run wdio:android:cosmedics:provider:profile)
# COSMEDICS_PROVIDER_PROFILE_ENTRY_PAUSE_MS=1500
